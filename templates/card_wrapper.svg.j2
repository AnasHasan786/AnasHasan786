<svg width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="cardBorderGlow" x1="0" y1="0" x2="{{ width }}" y2="{{ height }}">
      <stop offset="0%" stop-color="{{ colors.primary }}" stop-opacity="0.35" />
      <stop offset="100%" stop-color="{{ colors.border }}" stop-opacity="0" />
    </linearGradient>
  </defs>

  <!-- card background -->
  <rect x="0.5" y="0.5" width="{{ width - 1 }}" height="{{ height - 1 }}" rx="12" ry="12"
        fill="{{ colors.card }}" stroke="{{ colors.border }}" stroke-width="1" />
  <rect x="0.5" y="0.5" width="{{ width - 1 }}" height="{{ height - 1 }}" rx="12" ry="12"
        fill="none" stroke="url(#cardBorderGlow)" stroke-width="1" />

  {% if title %}
  <text x="24" y="34" font-family="{{ font }}" font-size="15" font-weight="600"
        fill="{{ colors.text }}" text-anchor="start">{{ title }}</text>
  {% endif %}
  {% if subtitle %}
  <text x="24" y="52" font-family="{{ font }}" font-size="11.5" font-weight="400"
        fill="{{ colors.subtext }}" text-anchor="start">{{ subtitle }}</text>
  {% endif %}
  {% if icon_svg %}
  <g transform="translate({{ width - 44 }}, 18)">{{ icon_svg | safe }}</g>
  {% endif %}

  {{ inner_svg | safe }}
</svg>
